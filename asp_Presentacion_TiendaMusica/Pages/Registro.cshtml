@page
@model asp_Presentacion_TiendaMusica.Pages.RegistroModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aurum Sound — Registro</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: sans-serif;
            min-height: 100vh;
            background-color: #0d0a04;
            background-image: radial-gradient(circle at 20% 50%, rgba(240,192,64,0.08) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(240,192,64,0.06) 0%, transparent 40%);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .bg-icon {
            position: fixed;
            color: rgba(240,192,64,0.07);
            font-size: 120px;
            pointer-events: none;
        }

        .login-container {
            width: 100%;
            max-width: 380px;
            z-index: 2;
        }

        .login-header {
            background: rgba(240,192,64,0.12);
            border: 0.5px solid rgba(240,192,64,0.3);
            border-bottom: none;
            border-radius: 12px 12px 0 0;
            padding: 2rem 1.5rem;
            text-align: center;
        }

        .logo-circle {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #F0C040;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 14px;
        }

        .login-body {
            background: rgba(15,10,3,0.88);
            border: 0.5px solid rgba(240,192,64,0.25);
            border-top: none;
            border-radius: 0 0 12px 12px;
            padding: 1.5rem;
        }

        .form-label {
            font-size: 13px;
            color: #9a8060;
            margin-bottom: 6px;
            display: block;
        }

        .form-input {
            width: 100%;
            padding: 9px 12px;
            border: 0.5px solid rgba(240,192,64,0.25);
            border-radius: 8px;
            font-size: 14px;
            background: rgba(255,255,255,0.05);
            color: #f0e8d0;
            margin-bottom: 14px;
        }

            .form-input::placeholder {
                color: #5a4a30;
            }

        .btn-gold {
            background: #F0C040;
            color: #1a1208;
            border: none;
            border-radius: 8px;
            padding: 10px 20px;
            font-size: 14px;
            font-weight: 500;
            width: 100%;
            cursor: pointer;
        }

        .form-group {
            margin-bottom: 14px;
        }

        .tagline {
            font-size: 11px;
            letter-spacing: 0.12em;
            color: #C8960C;
            margin-bottom: 6px;
        }

        .error-msg {
            background: rgba(220,60,60,0.15);
            border: 0.5px solid rgba(220,60,60,0.3);
            color: #e07070;
            font-size: 13px;
            padding: 9px 12px;
            border-radius: 8px;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
    </style>
</head>
<body>
    <i class="ti ti-guitar bg-icon" style="top:10%; right:5%;"></i>
    <i class="ti ti-microphone bg-icon" style="bottom:5%; left:5%;"></i>
    <i class="ti ti-vinyl bg-icon" style="bottom:10%; right:3%; font-size:160px;"></i>
    <i class="ti ti-music bg-icon" style="top:5%; left:3%; font-size:80px;"></i>

    <div class="login-container">
        <div class="login-header">
            <div class="logo-circle">
                <i class="ti ti-music" style="font-size:26px; color:#1a1208;"></i>
            </div>
            <p class="tagline">ÚNETE A</p>
            <p style="font-size:26px; font-weight:500; color:#F0C040; letter-spacing:0.04em;">
                Aurum Sound
            </p>
            <p style="font-size:12px; color:#9a8060; margin-top:6px;">
                Crea tu cuenta para comenzar
            </p>
        </div>
        <div class="login-body">

            @if (!string.IsNullOrEmpty(Model.ErrorMensaje))
            {
                <div class="error-msg">
                    <i class="ti ti-alert-circle" style="font-size:16px;"></i>
                    @Model.ErrorMensaje
                </div>
            }

            <form method="post">
                <div class="form-group">
                    <label class="form-label">
                        <i class="ti ti-user" style="font-size:14px; margin-right:4px;"></i>
                        Nombre de usuario
                    </label>
                    <input class="form-input" type="text"
                           asp-for="Username" placeholder="Ej: carlos.vendedor" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="ti ti-lock" style="font-size:14px; margin-right:4px;"></i>
                        Contraseña
                    </label>
                    <input class="form-input" type="password"
                           asp-for="Password" placeholder="Mínimo 6 caracteres" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="ti ti-lock-check" style="font-size:14px; margin-right:4px;"></i>
                        Confirmar contraseña
                    </label>
                    <input class="form-input" type="password"
                           asp-for="ConfirmarPassword" placeholder="Repite tu contraseña" />
                </div>

                <button type="submit" class="btn-gold">
                    <i class="ti ti-user-plus" style="font-size:15px; margin-right:6px;
                       vertical-align:-2px;"></i>
                    Crear cuenta
                </button>
            </form>

            <p style="font-size:12px; color:#5a4a30; text-align:center; margin-top:14px;">
                ¿Ya tienes cuenta?
                <a href="/Login" style="color:#F0C040; text-decoration:none;">
                    Inicia sesión
                </a>
            </p>
        </div>
    </div>
</body>
</html>
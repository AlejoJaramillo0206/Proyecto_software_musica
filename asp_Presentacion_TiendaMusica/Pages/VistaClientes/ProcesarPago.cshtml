@page
@model asp_Presentacion_TiendaMusica.Pages.VistaClientes.ProcesarPagoModel

@{
    ViewData["Title"] = "Proceder al Pago";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .page-title {
        font-size: 36px;
        font-weight: 800;
        color: #f5c542;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .pago-grid {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 24px;
        align-items: start;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        color: #f5c542;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
        padding-bottom: 12px;
        border-bottom: 1px solid #2a2a2a;
    }

   
    .resumen-card {
        background: #111111;
        border: 1px solid #2a2a2a;
        border-radius: 20px;
        padding: 24px;
    }

    .resumen-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid #1e1e1e;
        font-size: 14px;
        color: #d0c0a0;
    }

        .resumen-item:last-of-type {
            border-bottom: none;
        }

    .resumen-nombre {
        font-weight: 500;
    }

    .resumen-detalle {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 2px;
    }

    .resumen-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid #f5c542;
    }

        .resumen-total span:first-child {
            font-size: 16px;
            font-weight: 700;
            color: #f0e8d0;
        }

        .resumen-total span:last-child {
            font-size: 24px;
            font-weight: 800;
            color: #f5c542;
        }

    /* Métodos de pago */
    .metodos-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        margin-bottom: 2rem;
    }

    .metodo-label {
        cursor: pointer;
        display: block;
    }

        .metodo-label input[type="radio"] {
            display: none;
        }

    .metodo-card {
        background: #111111;
        border: 2px solid #2a2a2a;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        transition: 0.2s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    .metodo-label input[type="radio"]:checked + .metodo-card {
        border-color: #f5c542;
        background: rgba(245,197,66,0.08);
    }

    .metodo-card:hover {
        border-color: rgba(245,197,66,0.4);
    }

    .metodo-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: rgba(245,197,66,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #f5c542;
    }

    .metodo-nombre {
        font-size: 14px;
        font-weight: 600;
        color: #f0e8d0;
    }

    .metodo-cuotas {
        font-size: 12px;
        color: #9ca3af;
    }

    /* Boton pagar */
    .btn-pagar {
        background: #f5c542;
        color: #1a1208;
        border: none;
        border-radius: 14px;
        padding: 14px 28px;
        font-size: 16px;
        font-weight: 700;
        width: 100%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: 0.2s ease;
        margin-top: 1rem;
    }

        .btn-pagar:hover {
            background: #e0b030;
        }

    .btn-volver {
        background: transparent;
        color: #9ca3af;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 10px 20px;
        font-size: 14px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 2rem;
        transition: 0.2s ease;
    }

        .btn-volver:hover {
            color: #f5c542;
            border-color: #f5c542;
        }

    .error-msg {
        background: rgba(220,60,60,0.12);
        border: 1px solid rgba(220,60,60,0.25);
        color: #e07070;
        font-size: 13px;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .seguridad {
        font-size: 12px;
        color: #6a5a3a;
        text-align: center;
        margin-top: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }
</style>

<a href="/VistaClientes/Carrito" class="btn-volver">
    <i class="fa-solid fa-arrow-left"></i>
    Volver al carrito
</a>

<h1 class="page-title">
    <i class="fa-solid fa-credit-card"></i>
    Proceder al Pago
</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMensaje))
{
    <div class="error-msg">
        <i class="fa-solid fa-circle-exclamation"></i>
        @Model.ErrorMensaje
    </div>
}

<form method="post">
    <div class="pago-grid">

      
        <div>
            <p class="section-title">
                <i class="fa-solid fa-wallet"></i>
                Elige tu método de pago
            </p>

            <div class="metodos-grid">
                @if (Model.MetodosPago != null)
                {
                    @foreach (var metodo in Model.MetodosPago)
                    {
                        var icono = metodo.Nombre switch
                        {
                            "Efectivo" => "fa-money-bill-wave",
                            "Tarjeta Debito" => "fa-credit-card",
                            "Tarjeta Credito" => "fa-credit-card",
                            "Transferencia" => "fa-building-columns",
                            _ => "fa-wallet"
                        };

                        <label class="metodo-label">
                            <input type="radio" name="MetodoPagoId"
                                   value="@metodo.Id" />
                            <div class="metodo-card">
                                <div class="metodo-icon">
                                    <i class="fa-solid @icono"></i>
                                </div>
                                <span class="metodo-nombre">@metodo.Nombre</span>
                                @if (metodo.NumCuotas > 1)
                                {
                                    <span class="metodo-cuotas">
                                        Hasta @metodo.NumCuotas cuotas
                                    </span>
                                }
                                else
                                {
                                    <span class="metodo-cuotas">Pago único</span>
                                }
                            </div>
                        </label>
                    }
                }
            </div>
        </div>

        <!-- Lado derecho: resumen del pedido -->
        <div>
            <p class="section-title">
                <i class="fa-solid fa-receipt"></i>
                Resumen del pedido
            </p>

            <div class="resumen-card">
                @foreach (var item in Model.Carrito)
                {
                    <div class="resumen-item">
                        <div>
                            <p class="resumen-nombre">@item.Nombre</p>
                            <p class="resumen-detalle">
                                @item.Cantidad x $@item.Precio.ToString("N0")
                            </p>
                        </div>
                        <span style="color:#f5c542; font-weight:600;">
                            $@item.Total.ToString("N0")
                        </span>
                    </div>
                }

                <div class="resumen-total">
                    <span>Total a pagar</span>
                    <span>$@Model.TotalPagar.ToString("N0")</span>
                </div>
            </div>

            <button type="submit" class="btn-pagar">
                <i class="fa-solid fa-lock"></i>
                Confirmar y pagar $@Model.TotalPagar.ToString("N0")
            </button>

            <p class="seguridad">
                <i class="fa-solid fa-shield-halved"></i>
                Pago seguro — Aurum Sound
            </p>
        </div>

    </div>
</form>
@page
@model asp_Presentacion_TiendaMusica.Pages.VistaClientes.CompletarPerfilModel

@{
    ViewData["Title"] = "Mi Perfil";
    Layout = "_Layout";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 32px;
        font-weight: 800;
        color: #f5c542;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .aviso-perfil {
        background: rgba(245,197,66,0.08);
        border: 1px solid rgba(245,197,66,0.3);
        border-radius: 14px;
        padding: 14px 18px;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 14px;
        color: #f5c542;
    }

    .alert-success {
        background: rgba(100,180,60,0.12);
        border: 1px solid rgba(100,180,60,0.25);
        color: #7ec850;
        font-size: 13px;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .error-msg {
        background: rgba(220,60,60,0.12);
        border: 1px solid rgba(220,60,60,0.25);
        color: #e07070;
        font-size: 13px;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-wrapper {
        max-width: 700px;
    }

    .form-section {
        background: linear-gradient(145deg, #111111, #1a1a1a);
        border: 1px solid #2a2a2a;
        border-radius: 20px;
        padding: 28px;
        margin-bottom: 20px;
    }

    .form-section-title {
        font-size: 16px;
        font-weight: 600;
        color: #f5c542;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding-bottom: 12px;
        border-bottom: 1px solid #2a2a2a;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .form-group.full {
            grid-column: span 2;
        }

    .form-label {
        font-size: 13px;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .form-input, .form-select {
        padding: 10px 14px;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        font-size: 14px;
        background: #0d0d0d;
        color: #f0e8d0;
        transition: 0.2s ease;
    }

        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #f5c542;
        }

    .toggle-group {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        background: #0d0d0d;
    }

    .toggle-label {
        font-size: 14px;
        color: #d0c0a0;
    }

    .btn-submit {
        background: #f5c542;
        color: #1a1208;
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        justify-content: center;
    }

        .btn-submit:hover {
            background: #e0b030;
        }
</style>

<div class="page-header">
    <h1 class="page-title">
        <i class="fa-solid fa-user-pen"></i>
        Mi Perfil
    </h1>
</div>

<div class="aviso-perfil">
    <i class="fa-solid fa-circle-info" style="font-size:18px;"></i>
    Completa tu perfil para poder realizar compras en Aurum Sound.
</div>

@if (!string.IsNullOrEmpty(Model.ExitoMensaje))
{
    <div class="alert-success">
        <i class="fa-solid fa-circle-check"></i>
        @Model.ExitoMensaje
    </div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMensaje))
{
    <div class="error-msg">
        <i class="fa-solid fa-circle-exclamation"></i>
        @Model.ErrorMensaje
    </div>
}

<div class="form-wrapper">
    <form method="post">

       
        <div class="form-section">
            <p class="form-section-title">
                <i class="fa-solid fa-user"></i>
                Datos personales
            </p>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-user"></i> Nombre completo
                    </label>
                    <input class="form-input" type="text"
                           asp-for="Nombre"
                           placeholder="Ej: Carlos Pérez" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-id-card"></i> Cédula
                    </label>
                    <input class="form-input" type="text"
                           asp-for="Cedula"
                           placeholder="Ej: 1234567890" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-location-dot"></i> Dirección
                    </label>
                    <input class="form-input" type="text"
                           asp-for="Direccion"
                           placeholder="Ej: Calle 10 #20-30" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-venus-mars"></i> Género
                    </label>
                    <select class="form-select" asp-for="Genero">
                        <option value="">Seleccionar...</option>
                        <option value="Masculino">Masculino</option>
                        <option value="Femenino">Femenino</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>
            </div>
        </div>

  
        <div class="form-section">
            <p class="form-section-title">
                <i class="fa-solid fa-address-card"></i>
                Información adicional
            </p>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-envelope"></i> Correo electrónico
                    </label>
                    <input class="form-input" type="email"
                           asp-for="Correo"
                           placeholder="Ej: carlos@email.com" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-calendar"></i> Fecha de nacimiento
                    </label>
                    <input class="form-input" type="date"
                           asp-for="FechaNacimiento" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-briefcase"></i> Profesión
                    </label>
                    <input class="form-input" type="text"
                           asp-for="Profesion"
                           placeholder="Ej: Ingeniero" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-star"></i> Marca favorita
                    </label>
                    <input class="form-input" type="text"
                           asp-for="MarcaFav"
                           placeholder="Ej: Gibson" />
                </div>
                <div class="form-group full">
                    <label class="form-label">
                        <i class="fa-solid fa-music"></i> ¿Eres músico?
                    </label>
                    <div class="toggle-group">
                        <input type="checkbox" asp-for="EsMusico"
                               id="esMusicoCheck" />
                        <label class="toggle-label" for="esMusicoCheck">
                            Soy músico o estudio música
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <button type="submit" class="btn-submit">
            <i class="fa-solid fa-floppy-disk"></i>
            Guardar perfil
        </button>
    </form>
</div>
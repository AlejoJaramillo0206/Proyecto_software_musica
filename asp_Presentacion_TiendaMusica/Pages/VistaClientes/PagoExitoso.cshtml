@page
@model asp_Presentacion_TiendaMusica.Pages.VistaClientes.PagoExitosoModel

@{
    ViewData["Title"] = "Pago Exitoso";
    Layout = "_Layout";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .exito-container {
        max-width: 560px;
        margin: 4rem auto;
        text-align: center;
    }

    .exito-icon {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: rgba(100,180,60,0.15);
        border: 2px solid rgba(100,180,60,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem;
        font-size: 48px;
        color: #7ec850;
        animation: pop 0.4s ease;
    }

    @@keyframes pop {
        0%

    {
        transform: scale(0.5);
        opacity: 0;
    }

    80% {
        transform: scale(1.1);
    }

    100% {
        transform: scale(1);
        opacity: 1;
    }

    }

    .exito-titulo {
        font-size: 36px;
        font-weight: 800;
        color: #f5c542;
        margin-bottom: 12px;
    }

    .exito-subtitulo {
        font-size: 16px;
        color: #9ca3af;
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    .factura-badge {
        background: rgba(245,197,66,0.1);
        border: 1px solid rgba(245,197,66,0.3);
        border-radius: 14px;
        padding: 16px 24px;
        display: inline-block;
        margin-bottom: 2rem;
    }

        .factura-badge p:first-child {
            font-size: 12px;
            color: #9ca3af;
            margin-bottom: 4px;
        }

        .factura-badge p:last-child {
            font-size: 22px;
            font-weight: 700;
            color: #f5c542;
            letter-spacing: 0.05em;
        }

    .botones {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-tienda {
        background: #f5c542;
        color: #1a1208;
        border: none;
        border-radius: 12px;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.2s ease;
    }

        .btn-tienda:hover {
            background: #e0b030;
        }

    .btn-mis-compras {
        background: transparent;
        color: #9ca3af;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 12px 24px;
        font-size: 14px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.2s ease;
    }

        .btn-mis-compras:hover {
            color: #f5c542;
            border-color: #f5c542;
        }
</style>

<div class="exito-container">

    <div class="exito-icon">
        <i class="fa-solid fa-check"></i>
    </div>

    <h1 class="exito-titulo">¡Pago exitoso!</h1>

    <p class="exito-subtitulo">
        Tu compra ha sido procesada correctamente.<br>
        Guarda el código de tu factura para cualquier consulta.
    </p>

    <div class="factura-badge">
        <p>Código de factura</p>
        <p>@(Model.CodigoFactura ?? "—")</p>
    </div>

    <div class="botones">
        <a href="/VistaClientes/DashboardCliente" class="btn-tienda">
            <i class="fa-solid fa-music"></i>
            Seguir comprando
        </a>
        <a href="/VistaClientes/MisCompras" class="btn-mis-compras">
            <i class="fa-solid fa-bag-shopping"></i>
            Ver mis compras
        </a>
    </div>

</div>
@page
@model asp_Presentacion_TiendaMusica.Pages.VistaClientes.DashboardClienteModel
@{
    ViewData["Title"] = "DashboardCliente";

    
    ViewData["Title"] = "...";
    Layout = "_Layout";

    var imagenesAlbumes = new Dictionary<string, string>
    {
        { "Midnights",                  "Midnights.png" },
        { "Renaissance",                "Renaissance.png" },
        { "Harrys House",               "HarrysHouse.png" },
        { "Back in Black",              "BackInBlack.png" },
        { "Rumours",                    "Rumours.png" },
        { "The Dark Side of the Moon",  "TheDarkSideoftheMoon.png" },
        { "El Ultimo Tour del Mundo",   "ElUltimoTourdelMundo.png" },
        { "Jose",                       "Jose.png" },
        { "Legendaddy",                 "Legendaddy.png" },
        { "La Novena Sinfonia",         "LaNovenaSinfonia.png" },
        { "Las Cuatro Estaciones",      "LasCuatroEstaciones.png" },
        { "Requiem en Re Menor",        "RequiemenReMenor.png" },
        { "Correa Levys Cuero",           "CorreaLevysCuero.png" },
    { "Pedal Boss DS-1",              "PedalBossDS-1.png" },
    { "Afinador Korg CA-50",          "AfinadorKorgCA-50.png" },
    };

}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    body {
        background: #050505;
    }

    .dashboard-container {
        min-height: 100vh;
        padding: 35px;
        background: radial-gradient(circle at top left, rgba(255,183,0,0.10), transparent 25%), radial-gradient(circle at bottom right, rgba(255,183,0,0.08), transparent 25%), #050505;
        color: white;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

        .dashboard-header h1 {
            font-size: 42px;
            font-weight: 800;
            color: #f5c542;
            margin-bottom: 8px;
        }

        .dashboard-header p {
            color: #9ca3af;
            font-size: 15px;
        }

    .cliente-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f5c542, #e0a800);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: 800;
        color: #1a1208;
    }

    .cliente-info {
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .cliente-info h4 {
            font-size: 16px;
            font-weight: 700;
        }

        .cliente-info span {
            color: #9ca3af;
            font-size: 13px;
        }

   
    .hero {
        background: linear-gradient(135deg, rgba(245,197,66,0.15), rgba(224,168,0,0.08));
        border: 1px solid rgba(245,197,66,0.2);
        border-radius: 24px;
        padding: 45px 50px;
        margin-bottom: 35px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: "";
            position: absolute;
            width: 350px;
            height: 350px;
            border-radius: 50%;
            background: rgba(245,197,66,0.06);
            top: -100px;
            right: -100px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

        .hero-content h2 {
            font-size: 38px;
            font-weight: 800;
            margin-bottom: 12px;
        }

        .hero-content p {
            color: #9ca3af;
            font-size: 16px;
            margin-bottom: 25px;
        }

    .hero-icon {
        font-size: 120px;
        position: relative;
        z-index: 2;
    }

    .btn-primary {
        padding: 12px 24px;
        border: none;
        border-radius: 12px;
        background: #f5c542;
        color: #1a1208;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        transition: 0.3s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-primary:hover {
            background: #e0b030;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(245,197,66,0.3);
        }

    
    .cards-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 35px;
  
    }

    .stat-card {
        background: linear-gradient(145deg, #111111, #1a1a1a);
        border: 1px solid #2a2a2a;
        border-radius: 20px;
        padding: 25px;
        transition: 0.3s;
  
    }

        .stat-card:hover {
            transform: translateY(-4px);
            border-color: rgba(245,197,66,0.3);
            box-shadow: 0 10px 25px rgba(245,197,66,0.08);
       
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: rgba(245,197,66,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #f5c542;
        margin-bottom: 18px;
    }

    .stat-card h2 {
        font-size: 36px;
        font-weight: 800;
        color: #f5c542;
        margin-bottom: 5px;
    }

    .stat-card p {
        color: #9ca3af;
        font-size: 13px;
    }

    
    .section-title {
        font-size: 24px;
        font-weight: 800;
        color: #f5c542;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .product-card {
        background: linear-gradient(145deg, #111111, #1a1a1a);
        border: 1px solid #2a2a2a;
        border-radius: 20px;
        overflow: hidden;
        transition: 0.3s;
    }

        .product-card:hover {
            transform: translateY(-5px);
            border-color: rgba(245,197,66,0.3);
            box-shadow: 0 12px 30px rgba(245,197,66,0.1);
        }

    .product-image {
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 70px;
        background: linear-gradient(135deg, #1a1208, #2a1e08);
        border-bottom: 1px solid #2a2a2a;
        overflow: hidden;
    }

    .product-body {
        padding: 20px;
    }

        .product-body h3 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 8px;
        }

    .product-codigo {
        color: #9ca3af;
        font-size: 13px;
        margin-bottom: 12px;
    }

    .product-price {
        font-size: 26px;
        font-weight: 800;
        color: #f5c542;
        margin-bottom: 15px;
    }

    .btn-buy {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: rgba(245,197,66,0.12);
        border: 1px solid rgba(245,197,66,0.2);
        color: #f5c542;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-buy:hover {
            background: #f5c542;
            color: #1a1208;
            transform: translateY(-2px);
        }

    @@media (max-width: 900px) {
        .cards-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .products-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .dashboard-container {
            padding: 20px;
        }

        .hero {
            flex-direction: column;
            gap: 20px;
        }
    }

    @@media (max-width: 500px) {
        .cards-grid {
            grid-template-columns: 1fr;
        }

        .products-grid {
            grid-template-columns: 1fr;
        }
    }

    .floating-cart {
        position: fixed;
        bottom: 35px;
        right: 35px;
        width: 65px;
        height: 65px;
        background: linear-gradient(135deg, #f5c542, #e0a800);
        color: #1a1208 !important;
        border-radius: 50%;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        font-size: 24px;
        box-shadow: 0 10px 25px rgba(245,197,66,0.3);
        transition: all 0.3s ease;
        text-decoration: none;
        z-index: 99999;
    }

        .floating-cart:hover {
            transform: scale(1.1) translateY(-3px);
            box-shadow: 0 15px 30px rgba(245,197,66,0.5);
            color: #1a1208 !important;
        }

   
    .cart-badge {
        position: absolute;
        top: -2px;
        right: -2px;
        background: #ff3b30;
        color: white !important;
        font-size: 11px;
        font-weight: 800;
        padding: 3px 7px;
        border-radius: 50%;
        border: 2px solid #050505;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        line-height: 1;
    }
</style>



<div class="dashboard-container">

    <div class="dashboard-header">
        <div>
            <h1>Bienvenido </h1>
            <p>Explora los mejores productos musicales</p>
        </div>
        <div class="cliente-info">
            <div class="cliente-avatar">
                @Model.Cliente?.Username?.Substring(0, 1).ToUpper()
            </div>

        </div>
    </div>

    <div class="hero">
        <div class="hero-content">
            <h2>Tu tienda de música favorita</h2>
            <p>Descubre álbumes, instrumentos y accesorios premium.</p>
           
        </div>
       
    </div>

    <div class="cards-grid">
        <div class="stat-card">
            <div class="stat-icon"><i class="fa-solid fa-box"></i></div>
            <h2>@Model.TotalProductos</h2>
            <p>Productos disponibles</p>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fa-solid fa-receipt"></i></div>
            <h2>@Model.TotalCompras</h2>
            <p>Mis compras</p>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fa-solid fa-screwdriver-wrench"></i></div>
            <h2>@Model.TotalGarantias</h2>
            <p>Garantías activas</p>
        </div>
    </div>

    <div class="section-title">
        <i class="fa-solid fa-star"></i> Productos Destacados
    </div>

    <div class="products-grid">
        @foreach (var producto in Model.ProductosDestacados)
        {
            <div class="product-card">
                <div class="product-image">
                    @if (imagenesAlbumes.ContainsKey(producto.Nombre))
                    {
                        <img src="/imagenes/@imagenesAlbumes[producto.Nombre]"
                             alt="@producto.Nombre"
                             style="width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <span>🎵</span>
                    }
                </div>
                <div class="product-body">
                    <h3>@producto.Nombre</h3>
                    <div class="product-codigo">@producto.Codigo</div>
                    <div class="product-price">$@producto.Precio.ToString("N0")</div>
                    <form method="post" asp-page-handler="AgregarAlCarrito">
                        <input type="hidden" name="idProducto" value="@producto.Id" />
                        <input type="hidden" name="nombre" value="@producto.Nombre" />
                        <input type="hidden" name="precio" value="@producto.Precio" />
                        <input type="hidden" name="codigo" value="@producto.Codigo" />
                        <button type="submit" class="btn-buy">
                            <i class="fa-solid fa-cart-shopping"></i> Comprar
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>

</div> @if (Model.CantidadCarrito > 0)
{
    <a href="/VistaClientes/Carrito" class="floating-cart" title="Ver mi carrito">
        <i class="fa-solid fa-cart-shopping"></i>
        <span class="cart-badge">@Model.CantidadCarrito</span>
    </a>
}
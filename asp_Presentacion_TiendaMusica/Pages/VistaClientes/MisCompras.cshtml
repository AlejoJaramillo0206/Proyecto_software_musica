@page
@model asp_Presentacion_TiendaMusica.Pages.VistaClientes.MisComprasModel

@{
    ViewData["Title"] = "Mis Compras";
    Layout = "_Layout";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .page-title {
        font-size: 32px;
        font-weight: 800;
        color: #f5c542;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: #111111;
        border: 1px solid #2a2a2a;
        border-radius: 20px;
        padding: 20px 24px;
        transition: 0.3s ease;
    }

    .stat-card:hover { border-color: #f5c542; }

    .stat-label {
        font-size: 13px;
        color: #9ca3af;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .stat-value {
        font-size: 26px;
        font-weight: 800;
        color: #f5c542;
    }

    .compra-card {
        background: linear-gradient(145deg, #111111, #1a1a1a);
        border: 1px solid #2a2a2a;
        border-radius: 20px;
        padding: 20px 24px;
        margin-bottom: 16px;
        transition: 0.2s ease;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
    }

    .compra-card:hover { border-color: rgba(245,197,66,0.3); }

    .compra-codigo {
        font-size: 16px;
        font-weight: 700;
        color: #f0e8d0;
        margin-bottom: 6px;
    }

    .compra-fecha {
        font-size: 13px;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .compra-total {
        font-size: 22px;
        font-weight: 800;
        color: #f5c542;
        white-space: nowrap;
    }

    .btn-detalle {
        background: rgba(245,197,66,0.12);
        color: #f5c542;
        border: 1px solid rgba(245,197,66,0.2);
        border-radius: 10px;
        padding: 8px 16px;
        font-size: 13px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: 0.2s ease;
        white-space: nowrap;
    }

    .btn-detalle:hover {
        background: rgba(245,197,66,0.25);
        border-color: #f5c542;
    }

    .compra-info { flex: 1; }

    .compra-acciones {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 10px;
    }

    .error-msg {
        background: rgba(220,60,60,0.12);
        border: 1px solid rgba(220,60,60,0.25);
        color: #e07070;
        font-size: 13px;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #9ca3af;
    }

    .empty-state i {
        font-size: 56px;
        color: #2a2a2a;
        margin-bottom: 1rem;
        display: block;
    }

    .empty-state p {
        font-size: 16px;
        margin-bottom: 1.5rem;
    }

    .btn-tienda {
        background: #f5c542;
        color: #1a1208;
        border: none;
        border-radius: 12px;
        padding: 10px 22px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-tienda:hover { background: #e0b030; }
</style>

<h1 class="page-title">
    <i class="fa-solid fa-bag-shopping"></i>
    Mis Compras
</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMensaje))
{
    <div class="error-msg">
        <i class="fa-solid fa-circle-exclamation"></i>
        @Model.ErrorMensaje
    </div>
}

@if (Model.Lista != null && Model.Lista.Any())
{

    <div class="stats-row">
        <div class="stat-card">
            <p class="stat-label">
                <i class="fa-solid fa-receipt"></i>
                Total compras
            </p>
            <p class="stat-value">@Model.Lista.Count</p>
        </div>
        <div class="stat-card">
            <p class="stat-label">
                <i class="fa-solid fa-dollar-sign"></i>
                Total gastado
            </p>
            <p class="stat-value">
                $@Model.Lista.Sum(f => f.Total).ToString("N0")
            </p>
        </div>
        <div class="stat-card">
            <p class="stat-label">
                <i class="fa-solid fa-calendar"></i>
                Última compra
            </p>
            <p class="stat-value" style="font-size:16px; padding-top:6px;">
                @Model.Lista.First().Fecha.ToString("dd/MM/yyyy")
            </p>
        </div>
    </div>

   
    @foreach (var factura in Model.Lista)
    {
        <div class="compra-card">
            <div class="compra-info">
                <p class="compra-codigo">
                    <i class="fa-solid fa-file-invoice"
                       style="color:#f5c542; margin-right:8px;"></i>
                    @factura.Codigo
                </p>
                <p class="compra-fecha">
                    <i class="fa-solid fa-calendar"></i>
                    @factura.Fecha.ToString("dd/MM/yyyy HH:mm")
                </p>
            </div>
            <div class="compra-acciones">
                <p class="compra-total">$@factura.Total.ToString("N0")</p>
                <a href="/VistaClientes/DetalleFactura?id=@factura.Id"
                   class="btn-detalle">
                    <i class="fa-solid fa-eye"></i>
                    Ver detalle
                </a>
            </div>
        </div>
    }
}
else if (Model.ErrorMensaje == null)
{
    <div class="empty-state">
        <i class="fa-solid fa-bag-shopping"></i>
        <p>Aún no has realizado ninguna compra.</p>
        <a href="/VistaClientes/Tienda" class="btn-tienda">
            <i class="fa-solid fa-music"></i>
            Ir a la tienda
        </a>
    </div>
}
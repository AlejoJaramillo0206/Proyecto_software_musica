<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aurum Sound — @ViewData["Title"]</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: sans-serif;
            min-height: 100vh;
            background-color: #0d0a04;
            background-image: radial-gradient(circle at 10% 90%, rgba(240,192,64,0.07) 0%, transparent 40%), radial-gradient(circle at 90% 10%, rgba(240,192,64,0.05) 0%, transparent 35%);
            color: #d0c0a0;
            position: relative;
            overflow-x: hidden;
        }

        /* Iconos de fondo */
        .bg-icon {
            position: fixed;
            color: rgba(240,192,64,0.04);
            pointer-events: none;
            z-index: 0;
        }

        /* Navbar */
        .navbar {
            background: rgba(240,192,64,0.08);
            border-bottom: 0.5px solid rgba(240,192,64,0.2);
            padding: 12px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(6px);
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 500;
            color: #F0C040;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .nav-link {
            font-size: 13px;
            color: #6a5a3a;
            text-decoration: none;
            padding: 6px 10px;
            border-radius: 6px;
            transition: all 0.15s;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .nav-link:hover {
                color: #F0C040;
                background: rgba(240,192,64,0.08);
            }

            .nav-link.active {
                color: #F0C040;
                background: rgba(240,192,64,0.12);
            }

        /* Dropdown */
        .nav-dropdown {
            position: relative;
        }

        .nav-dropdown-menu {
            display: none;
            position: absolute;
            top: calc(100% + 6px);
            left: 0;
            background: #1a1208;
            border: 0.5px solid rgba(240,192,64,0.2);
            border-radius: 8px;
            padding: 6px;
            min-width: 180px;
            z-index: 200;
        }

        .nav-dropdown:hover .nav-dropdown-menu {
            display: block;
        }

        .nav-dropdown-item {
            font-size: 13px;
            color: #9a8060;
            text-decoration: none;
            padding: 7px 10px;
            border-radius: 6px;
            display: block;
        }

            .nav-dropdown-item:hover {
                color: #F0C040;
                background: rgba(240,192,64,0.08);
            }

        /* Separador en navbar */
        .nav-sep {
            width: 0.5px;
            height: 18px;
            background: rgba(240,192,64,0.2);
            margin: 0 6px;
        }

        /* Usuario en sesion */
        .nav-user {
            font-size: 13px;
            color: #9a8060;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .nav-user span {
                color: #F0C040;
                font-weight: 500;
            }

        /* Contenido principal */
        .main-content {
            padding: 2rem;
            position: relative;
            z-index: 1;
        }

        /* Titulo de pagina */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }

        .page-title {
            font-size: 20px;
            font-weight: 500;
            color: #F0C040;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .gold-bar {
            width: 4px;
            height: 24px;
            background: #F0C040;
            border-radius: 2px;
        }

        /* Cards */
        .card {
            background: rgba(255,255,255,0.03);
            border: 0.5px solid rgba(240,192,64,0.15);
            border-radius: 12px;
            padding: 1.25rem;
        }

        /* Botones */
        .btn-gold {
            background: #F0C040;
            color: #1a1208;
            border: none;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
        }

        .btn-outline {
            background: transparent;
            color: #9a8060;
            border: 0.5px solid rgba(240,192,64,0.2);
            border-radius: 8px;
            padding: 8px 14px;
            font-size: 13px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
        }

            .btn-outline:hover {
                color: #F0C040;
                border-color: rgba(240,192,64,0.4);
            }

        .btn-danger {
            background: rgba(220,60,60,0.15);
            color: #e07070;
            border: 0.5px solid rgba(220,60,60,0.2);
            border-radius: 8px;
            padding: 8px 14px;
            font-size: 13px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
        }

        /* Tabla */
        .table-wrapper {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        thead tr {
            background: rgba(240,192,64,0.1);
        }

        thead th {
            padding: 10px 14px;
            text-align: left;
            font-size: 12px;
            font-weight: 500;
            color: #C8960C;
            border-bottom: 0.5px solid rgba(240,192,64,0.2);
        }

        tbody tr {
            border-bottom: 0.5px solid rgba(240,192,64,0.08);
        }

            tbody tr:hover {
                background: rgba(240,192,64,0.04);
            }

        tbody td {
            padding: 10px 14px;
            color: #d0c0a0;
            font-size: 13px;
        }

        /* Formularios */
        .form-group {
            margin-bottom: 14px;
        }

        .form-label {
            font-size: 13px;
            color: #9a8060;
            margin-bottom: 6px;
            display: block;
        }

        .form-input, .form-select {
            width: 100%;
            padding: 9px 12px;
            border: 0.5px solid rgba(240,192,64,0.25);
            border-radius: 8px;
            font-size: 14px;
            background: rgba(255,255,255,0.05);
            color: #f0e8d0;
        }

            .form-input::placeholder {
                color: #5a4a30;
            }

        /* Badges */
        .badge {
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 6px;
            font-weight: 500;
        }

        .badge-crear {
            background: rgba(100,180,60,0.15);
            color: #7ec850;
        }

        .badge-editar {
            background: rgba(240,192,64,0.15);
            color: #F0C040;
        }

        .badge-eliminar {
            background: rgba(220,60,60,0.15);
            color: #e07070;
        }

        .badge-activo {
            background: rgba(100,180,60,0.15);
            color: #7ec850;
        }

        .badge-inactivo {
            background: rgba(220,60,60,0.15);
            color: #e07070;
        }

        /* Alertas */
        .alert-error {
            background: rgba(220,60,60,0.12);
            border: 0.5px solid rgba(220,60,60,0.25);
            color: #e07070;
            font-size: 13px;
            padding: 10px 14px;
            border-radius: 8px;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .alert-success {
            background: rgba(100,180,60,0.12);
            border: 0.5px solid rgba(100,180,60,0.25);
            color: #7ec850;
            font-size: 13px;
            padding: 10px 14px;
            border-radius: 8px;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
    </style>
</head>
<body>

    <i class="ti ti-vinyl bg-icon"
       style="bottom:-30px; right:-30px; font-size:300px;"></i>
    <i class="ti ti-music bg-icon"
       style="top:80px; left:-10px; font-size:100px;"></i>

    <!-- Navbar -->
    <nav class="navbar">
        <a class="navbar-brand" href="/Index">
            <i class="ti ti-music" style="font-size:20px;"></i>
            Aurum Sound
        </a>

        <div class="navbar-links">

            <!-- Productos dropdown -->
            <div class="nav-dropdown">
                <a class="nav-link" href="#">
                    <i class="ti ti-package" style="font-size:15px;"></i>
                    Productos
                    <i class="ti ti-chevron-down" style="font-size:12px;"></i>
                </a>
                <div class="nav-dropdown-menu">
                    <a class="nav-dropdown-item" href="/Productos">
                        <i class="ti ti-list" style="font-size:13px; margin-right:6px;"></i>
                        Todos los productos
                    </a>
                    <a class="nav-dropdown-item" href="/AlbumesClasicos">
                        <i class="ti ti-music" style="font-size:13px; margin-right:6px;"></i>
                        Álbumes Clásicos
                    </a>
                    <a class="nav-dropdown-item" href="/AlbumesPop">
                        <i class="ti ti-music" style="font-size:13px; margin-right:6px;"></i>
                        Álbumes Pop
                    </a>
                    <a class="nav-dropdown-item" href="/AlbumesReggaeton">
                        <i class="ti ti-music" style="font-size:13px; margin-right:6px;"></i>
                        Álbumes Reggaetón
                    </a>
                    <a class="nav-dropdown-item" href="/AlbumesRock">
                        <i class="ti ti-music" style="font-size:13px; margin-right:6px;"></i>
                        Álbumes Rock
                    </a>
                    <a class="nav-dropdown-item" href="/InstrumentosCuerdas">
                        <i class="ti ti-guitar" style="font-size:13px; margin-right:6px;"></i>
                        Instrumentos Cuerdas
                    </a>
                    <a class="nav-dropdown-item" href="/InstrumentosAire">
                        <i class="ti ti-microphone" style="font-size:13px; margin-right:6px;"></i>
                        Instrumentos Aire
                    </a>
                    <a class="nav-dropdown-item" href="/InstrumentosPercusion">
                        <i class="ti ti-music" style="font-size:13px; margin-right:6px;"></i>
                        Instrumentos Percusión
                    </a>
                    <a class="nav-dropdown-item" href="/Bafles">
                        <i class="ti ti-speakerphone" style="font-size:13px; margin-right:6px;"></i>
                        Bafles
                    </a>
                    <a class="nav-dropdown-item" href="/Accesorios">
                        <i class="ti ti-tool" style="font-size:13px; margin-right:6px;"></i>
                        Accesorios
                    </a>
                </div>
            </div>

            <!-- Clientes y Empleados -->
            <div class="nav-dropdown">
                <a class="nav-link" href="#">
                    <i class="ti ti-users" style="font-size:15px;"></i>
                    Personas
                    <i class="ti ti-chevron-down" style="font-size:12px;"></i>
                </a>
                <div class="nav-dropdown-menu">
                    <a class="nav-dropdown-item" href="/Clientes">
                        <i class="ti ti-user" style="font-size:13px; margin-right:6px;"></i>
                        Clientes
                    </a>
                    <a class="nav-dropdown-item" href="/Empleados">
                        <i class="ti ti-briefcase" style="font-size:13px; margin-right:6px;"></i>
                        Empleados
                    </a>
                    <a class="nav-dropdown-item" href="/Proveedores">
                        <i class="ti ti-truck" style="font-size:13px; margin-right:6px;"></i>
                        Proveedores
                    </a>
                </div>
            </div>

            <!-- Ventas -->
            <div class="nav-dropdown">
                <a class="nav-link" href="#">
                    <i class="ti ti-receipt" style="font-size:15px;"></i>
                    Ventas
                    <i class="ti ti-chevron-down" style="font-size:12px;"></i>
                </a>
                <div class="nav-dropdown-menu">
                    <a class="nav-dropdown-item" href="/Facturas">
                        <i class="ti ti-file-invoice" style="font-size:13px; margin-right:6px;"></i>
                        Facturas
                    </a>
                    <a class="nav-dropdown-item" href="/Pagos">
                        <i class="ti ti-credit-card" style="font-size:13px; margin-right:6px;"></i>
                        Pagos
                    </a>
                    <a class="nav-dropdown-item" href="/MetodosPago">
                        <i class="ti ti-wallet" style="font-size:13px; margin-right:6px;"></i>
                        Métodos de pago
                    </a>
                </div>
            </div>

            <!-- Operaciones -->
            <div class="nav-dropdown">
                <a class="nav-link" href="#">
                    <i class="ti ti-settings" style="font-size:15px;"></i>
                    Operaciones
                    <i class="ti ti-chevron-down" style="font-size:12px;"></i>
                </a>
                <div class="nav-dropdown-menu">
                    <a class="nav-dropdown-item" href="/Inventarios">
                        <i class="ti ti-box" style="font-size:13px; margin-right:6px;"></i>
                        Inventarios
                    </a>
                    <a class="nav-dropdown-item" href="/Garantias">
                        <i class="ti ti-shield" style="font-size:13px; margin-right:6px;"></i>
                        Garantías
                    </a>
                    <a class="nav-dropdown-item" href="/Reparaciones">
                        <i class="ti ti-tool" style="font-size:13px; margin-right:6px;"></i>
                        Reparaciones
                    </a>
                    <a class="nav-dropdown-item" href="/Reseñas">
                        <i class="ti ti-star" style="font-size:13px; margin-right:6px;"></i>
                        Reseñas
                    </a>
                </div>
            </div>

            <!-- Admin: solo visible para Administrador -->
            @if (Context.Session.GetString("Rol") == "Administrador")
            {
                <div class="nav-dropdown">
                    <a class="nav-link" href="#">
                        <i class="ti ti-shield-lock" style="font-size:15px;"></i>
                        Admin
                        <i class="ti ti-chevron-down" style="font-size:12px;"></i>
                    </a>
                    <div class="nav-dropdown-menu">
                        <a class="nav-dropdown-item" href="/Usuarios">
                            <i class="ti ti-user-cog" style="font-size:13px; margin-right:6px;"></i>
                            Usuarios
                        </a>
                        <a class="nav-dropdown-item" href="/Roles">
                            <i class="ti ti-key" style="font-size:13px; margin-right:6px;"></i>
                            Roles
                        </a>
                        <a class="nav-dropdown-item" href="/Auditorias">
                            <i class="ti ti-clipboard-list" style="font-size:13px; margin-right:6px;"></i>
                            Auditorías
                        </a>
                    </div>
                </div>
            }

            <div class="nav-sep"></div>

            <!-- Usuario en sesion -->
            <div class="nav-user">
                <i class="ti ti-user-circle" style="font-size:16px;"></i>
                <span>@Context.Session.GetString("Username")</span>
                <span style="color:#6a5a3a; font-size:11px;">
                    (@Context.Session.GetString("Rol"))
                </span>
            </div>

            <!-- Cerrar sesion -->
            <a class="nav-link" href="/Login"
               onclick="sessionStorage.clear()">
                <i class="ti ti-logout" style="font-size:15px;"></i>
            </a>
        </div>
    </nav>

    <!-- Contenido de cada pagina -->
    <main class="main-content">
        @RenderBody()
    </main>

</body>
</html>
            </a>

            <div class="navbar-links">

                <div class="nav-left">


                    <div class="nav-dropdown">

                        <a class="nav-link" href="#">
                            <i class="ti ti-package" style="font-size:15px;"></i>
                            Productos
                            <i class="ti ti-chevron-down" style="font-size:12px;"></i>
                        </a>

                        <div class="nav-dropdown-menu">

                            <a class="nav-dropdown-item" href="/VistaClientes/ProductoAlbumes">
                                <i class="ti ti-disc"
                                   style="font-size:13px; margin-right:6px;"></i>
                                Álbumes
                            </a>

                            <a class="nav-dropdown-item" href="/VistaClientes/ProductosInstrumentos">
                                <i class="ti ti-guitar-pick"
                                   style="font-size:13px; margin-right:6px;"></i>
                                Instrumentos
                            </a>

                            <a class="nav-dropdown-item" href="/VistaClientes/ProductoBafles">
                                <i class="ti ti-speakerphone"
                                   style="font-size:13px; margin-right:6px;"></i>
                                Bafles
                            </a>

                            <a class="nav-dropdown-item" href="/VistaClientes/ProductoAccesorios">
                                <i class="ti ti-tool"
                                   style="font-size:13px; margin-right:6px;"></i>
                                Accesorios
                            </a>

                        </div>
                    </div>

                    <div class="nav-dropdown">

                        <a class="nav-link" href="#">
                            <i class="ti ti-settings" style="font-size:15px;"></i>
                            Operaciones
                            <i class="ti ti-chevron-down" style="font-size:12px;"></i>
                        </a>

                        <div class="nav-dropdown-menu">

                            <a class="nav-dropdown-item" href="/VistaClientes/Garantias">
                                <i class="ti ti-shield"
                                   style="font-size:13px; margin-right:6px;"></i>
                                Garantías
                            </a>

                            <a class="nav-dropdown-item" href="/VistaClientes/Reparaciones">
                                <i class="ti ti-tool"
                                   style="font-size:13px; margin-right:6px;"></i>
                                Reparaciones
                            </a>

                            <a class="nav-dropdown-item" href="/VistaClientes/Reseñas?id=5">
                                <i class="ti ti-star"
                                   style="font-size:13px; margin-right:6px;"></i>
                                Reseñas
                            </a>

                        </div>
                    </div>



                </div>


                <div class="nav-right">

                    <div class="nav-sep"></div>


                    <div class="nav-dropdown">

                        <a class="nav-link" href="#">
                            <i class="ti ti-user-circle"
                               style="font-size:16px;"></i>

                            <span style="color:#F0C040;">
                                @Context.Session.GetString("Username")
                            </span>

                            <span style="color:#6a5a3a; font-size:11px;">
                                (@Context.Session.GetString("Rol"))
                            </span>

                            <i class="ti ti-chevron-down"
                               style="font-size:12px;"></i>
                        </a>

                        @{
                            var usuarioIdNav = Context.Session.GetString("UsuarioId");
                        }
                        @if (!string.IsNullOrEmpty(usuarioIdNav) &&
                                            Context.Session.GetString("Rol") == "Cliente" &&
                                            Context.Session.GetString("PerfilCompleto") != "true")
                        {
                            <a href="/VistaClientes/CompletarPerfil" style="color: gold;">
                                <i class="fa-solid fa-circle-exclamation"></i>
                                Completa tu perfil
                            </a>
                        }

                        <div class="nav-dropdown-menu"
                             style="right:0; left:auto;">

                            <a class="nav-dropdown-item" href="/VistaClientes/CompletarPerfil">
                                <i class="ti ti-user"
                                   style="font-size:13px; margin-right:6px;"></i>
                                Perfil
                            </a>

                            <a class="nav-dropdown-item"
                               href="/VistaClientes/MisCompras">

                                <i class="ti ti-history"
                                   style="font-size:13px; margin-right:6px;"></i>

                                Historial compras
                            </a>
                            <div style="
                                        height:1px;
                                        background:rgba(240,192,64,0.15);
                                        margin:6px 0;
                                    "></div>

                            <a class="nav-dropdown-item"
                               href="/Login"
                               onclick="sessionStorage.clear()"
                               style="color:#e07070;">

                                <i class="ti ti-logout" href="/Pages/CerrarSesion"
                                   style="font-size:13px; margin-right:6px;"></i>
                             
                                Cerrar sesión
                            </a>

                        </div>
                    </div>

                </div>

            </div>

        </nav>
    }

    @if (Context.Session.GetString("Rol") == "Administrador")
    {
        <nav class="navbar">


            <a class="navbar-brand" href="/Admin/Dashboard">
                <i class="ti ti-music" style="font-size:20px;"></i>
                Aurum Sound
            </a>

            <div class="navbar-links">


                <div class="nav-right">

                    <div class="nav-sep"></div>


                    <div class="nav-dropdown">

                        <a class="nav-link" href="#">
                            <i class="ti ti-user-circle"
                               style="font-size:16px;"></i>

                            <span style="color:#F0C040;">
                                @Context.Session.GetString("Username")
                            </span>

                            <span style="color:#6a5a3a; font-size:11px;">
                                (@Context.Session.GetString("Rol"))
                            </span>

                            <i class="ti ti-chevron-down"
                               style="font-size:12px;"></i>
                        </a>

                        <div class="nav-dropdown-menu"
                             style="right:0; left:auto;">




                            <div style="
                                            height:1px;
                                            background:rgba(240,192,64,0.15);
                                            margin:6px 0;
                                        "></div>

                            <a class="nav-dropdown-item"
                               href="/Login"
                               onclick="sessionStorage.clear()"
                               style="color:#e07070;">

                                <i class="ti ti-logout" href="/Pages/CerrarSesion"
                                   style="font-size:13px; margin-right:6px;"></i>

                                Cerrar sesión
                            </a>

                        </div>
                    </div>

                </div>

            </div>

        </nav>
    }

    <main class="main-content">
        @RenderBody()
    </main>

    @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")) && Context.Session.GetString("Rol") != "Administrador")
    {
        <a href="/VistaClientes/Carrito" class="floating-cart" title="Ver mi carrito">
            <i class="ti ti-shopping-cart"></i>
            @if (totalItems > 0)
            {
                <span class="cart-badge">@totalItems</span>
            }
        </a>
    }
   
    <script>
       
        window.addEventListener("beforeunload", function () {
            localStorage.setItem("scrollPosition", window.scrollY);
        });

       
        window.addEventListener("load", function () {
            if (localStorage.getItem("scrollPosition") !== null) {
                window.scrollTo(0, parseInt(localStorage.getItem("scrollPosition")));
                localStorage.removeItem("scrollPosition"); 
            }
        });
    </script>
 

</body>
</html>
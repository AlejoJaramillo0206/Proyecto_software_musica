@using Microsoft.AspNetCore.Http
@using System.Text.Json
@{

    var cartJson = Context.Session.GetString("Carrito");
    int totalItems = 0;
    if (!string.IsNullOrEmpty(cartJson))
    {
        try
        {
           
            using (JsonDocument doc = JsonDocument.Parse(cartJson))
            {
                if (doc.RootElement.ValueKind == JsonValueKind.Array)
                {
                    foreach (JsonElement item in doc.RootElement.EnumerateArray())
                    {
                        if (item.TryGetProperty("Cantidad", out JsonElement qty))
                        {
                            totalItems += qty.GetInt32();
                        }
                    }
                }
            }
        }
        catch { }
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aurum Sound — @ViewData["Title"]</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: sans-serif;
            min-height: 100vh;
            background-color: #0d0a04;
            background-image: radial-gradient(circle at 10% 90%, rgba(240,192,64,0.07) 0%, transparent 40%), radial-gradient(circle at 90% 10%, rgba(240,192,64,0.05) 0%, transparent 35%);
            color: #d0c0a0;
            position: relative;
            overflow-x: hidden;
        }


        .bg-icon {
            position: fixed;
            color: rgba(240,192,64,0.04);
            pointer-events: none;
            z-index: 0;
        }


        .navbar {
            background: rgba(240,192,64,0.08);
            border-bottom: 0.5px solid rgba(240,192,64,0.2);
            padding: 12px 24px;
            display: flex;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(6px);
        }


        .navbar-brand {
            font-size: 18px;
            font-weight: 500;
            color: #F0C040;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            margin-right: 40px;
            flex-shrink: 0;
        }


        .navbar-links {
            display: flex;
            align-items: center;
            width: 100%;
        }


        .nav-left {
            display: flex;
            align-items: center;
            gap: 6px;
        }


        .nav-right {
            margin-left: auto;
            display: flex;
            align-items: center;
        }

        .nav-link {
            font-size: 13px;
            color: #9a8060;
            text-decoration: none;
            padding: 6px 10px;
            border-radius: 6px;
            transition: all 0.15s;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .nav-link:hover {
                color: #F0C040;
                background: rgba(240,192,64,0.08);
            }

            .nav-link.active {
                color: #F0C040;
                background: rgba(240,192,64,0.12);
            }


        .nav-dropdown {
            position: relative;
        }

        .nav-dropdown-menu {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            background: #1a1208;
            border: 0.5px solid rgba(240,192,64,0.2);
            border-radius: 8px;
            padding: 6px;
            min-width: 180px;
            z-index: 200;
        }

        .nav-dropdown:hover .nav-dropdown-menu {
            display: block;
        }

        .nav-dropdown-item {
            font-size: 13px;
            color: #9a8060;
            text-decoration: none;
            padding: 7px 10px;
            border-radius: 6px;
            display: block;
        }

            .nav-dropdown-item:hover {
                color: #F0C040;
                background: rgba(240,192,64,0.08);
            }


        .nav-sep {
            width: 0.5px;
            height: 18px;
            background: rgba(240,192,64,0.2);
            margin: 0 10px;
        }


        .main-content {
            padding: 2rem;
            position: relative;
            z-index: 1;
        }


        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }

        .page-title {
            font-size: 20px;
            font-weight: 500;
            color: #F0C040;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .gold-bar {
            width: 4px;
            height: 24px;
            background: #F0C040;
            border-radius: 2px;
        }


        .card {
            background: rgba(255,255,255,0.03);
            border: 0.5px solid rgba(240,192,64,0.15);
            border-radius: 12px;
            padding: 1.25rem;
        }


        .btn-gold {
            background: #F0C040;
            color: #1a1208;
            border: none;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
        }

        .btn-outline {
            background: transparent;
            color: #9a8060;
            border: 0.5px solid rgba(240,192,64,0.2);
            border-radius: 8px;
            padding: 8px 14px;
            font-size: 13px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
        }

            .btn-outline:hover {
                color: #F0C040;
                border-color: rgba(240,192,64,0.4);
            }

        .btn-danger {
            background: rgba(220,60,60,0.15);
            color: #e07070;
            border: 0.5px solid rgba(220,60,60,0.2);
            border-radius: 8px;
            padding: 8px 14px;
            font-size: 13px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
        }


        .table-wrapper {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        thead tr {
            background: rgba(240,192,64,0.1);
        }

        thead th {
            padding: 10px 14px;
            text-align: left;
            font-size: 12px;
            font-weight: 500;
            color: #C8960C;
            border-bottom: 0.5px solid rgba(240,192,64,0.2);
        }

        tbody tr {
            border-bottom: 0.5px solid rgba(240,192,64,0.08);
        }

            tbody tr:hover {
                background: rgba(240,192,64,0.04);
            }

        tbody td {
            padding: 10px 14px;
            color: #d0c0a0;
            font-size: 13px;
        }


        .form-group {
            margin-bottom: 14px;
        }

        .form-label {
            font-size: 13px;
            color: #9a8060;
            margin-bottom: 6px;
            display: block;
        }

        .form-input, .form-select {
            width: 100%;
            padding: 9px 12px;
            border: 0.5px solid rgba(240,192,64,0.25);
            border-radius: 8px;
            font-size: 14px;
            background: rgba(255,255,255,0.05);
            color: #f0e8d0;
        }

            .form-input::placeholder {
                color: #5a4a30;
            }

        .badge {
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 6px;
            font-weight: 500;
        }

        .badge-crear {
            background: rgba(100,180,60,0.15);
            color: #7ec850;
        }

        .badge-editar {
            background: rgba(240,192,64,0.15);
            color: #F0C040;
        }

        .badge-eliminar {
            background: rgba(220,60,60,0.15);
            color: #e07070;
        }

        .badge-activo {
            background: rgba(100,180,60,0.15);
            color: #7ec850;
        }

        .badge-inactivo {
            background: rgba(220,60,60,0.15);
            color: #e07070;
        }

        .alert-error {
            background: rgba(220,60,60,0.12);
            border: 0.5px solid rgba(220,60,60,0.25);
            color: #e07070;
            font-size: 13px;
            padding: 10px 14px;
            border-radius: 8px;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .alert-success {
            background: rgba(100,180,60,0.12);
            border: 0.5px solid rgba(100,180,60,0.25);
            color: #7ec850;
            font-size: 13px;
            padding: 10px 14px;
            border-radius: 8px;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        
        .floating-cart {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #F0C040;
            color: #1a1208 !important;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            box-shadow: 0 8px 25px rgba(240,192,64,0.3);
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 999;
        }

            .floating-cart:hover {
                transform: scale(1.1) translateY(-4px);
                box-shadow: 0 12px 30px rgba(240,192,64,0.5);
                background: #f3cc62;
            }

        .cart-badge {
            position: absolute;
            top: -3px;
            right: -3px;
            background: #e07070;
            color: #1a1208;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 7px;
            border-radius: 12px;
            border: 2px solid #0d0a04;
            box-shadow: 0 4px 10px rgba(0,0,0,0.4);
        }
    </style>
</head>
<body>

    <i class="ti ti-vinyl bg-icon"
       style="bottom:-30px; right:-30px; font-size:300px;"></i>

    <i class="ti ti-music bg-icon"
       style="top:80px; left:-10px; font-size:100px;"></i>


    @if (Context.Session.GetString("Rol") != "Administrador")
    {
        <nav class="navbar">


            <a class="navbar-brand" href="/VistaClientes/DashboardCliente">
                <i class="ti ti-music" style="font-size:20px;"></i>

@page
@model asp_Presentacion_TiendaMusica.Pages.Admin.AgregarEmpleadoModel
@{
    ViewData["Title"] = "Agregar Empleado";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 2rem;
    }

    .btn-back {
        background: transparent;
        color: #9ca3af;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 8px 14px;
        font-size: 13px;
        cursor: pointer;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-back:hover {
            color: #f5c542;
            border-color: #f5c542;
        }

    .page-title {
        font-size: 32px;
        font-weight: 800;
        color: #f5c542;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-wrapper {
        max-width: 800px;
    }

    .form-section {
        background: linear-gradient(145deg, #111111, #1a1a1a);
        border: 1px solid #2a2a2a;
        border-radius: 20px;
        padding: 28px;
        margin-bottom: 20px;
    }

    .form-section-title {
        font-size: 16px;
        font-weight: 600;
        color: #f5c542;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding-bottom: 12px;
        border-bottom: 1px solid #2a2a2a;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .form-group.full {
            grid-column: span 2;
        }

    .form-label {
        font-size: 13px;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .form-input, .form-select {
        padding: 10px 14px;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        font-size: 14px;
        background: #0d0d0d;
        color: #f0e8d0;
        transition: 0.2s ease;
    }

        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #f5c542;
        }

        .form-input::placeholder {
            color: #3a3a3a;
        }

    .btn-submit {
        background: #f5c542;
        color: #1a1208;
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        justify-content: center;
    }

        .btn-submit:hover {
            background: #e0b030;
        }

    .error-msg {
        background: rgba(220,60,60,0.12);
        border: 1px solid rgba(220,60,60,0.25);
        color: #e07070;
        font-size: 13px;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="page-header">
    <a href="/Admin/Empleados" class="btn-back">
        <i class="fa-solid fa-arrow-left"></i>
        Volver
    </a>
    <h1 class="page-title">
        <i class="fa-solid fa-user-plus"></i>
        Agregar Empleado
    </h1>
</div>

<div class="form-wrapper">

    @if (!string.IsNullOrEmpty(Model.ErrorMensaje))
    {
        <div class="error-msg">
            <i class="fa-solid fa-circle-exclamation"></i>
            @Model.ErrorMensaje
        </div>
    }

    <form method="post">

        <!-- Datos personales -->
        <div class="form-section">
            <p class="form-section-title">
                <i class="fa-solid fa-user"></i>
                Datos personales
            </p>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-user"></i> Nombre completo
                    </label>
                    <input class="form-input" type="text"
                           asp-for="Nombre" placeholder="Ej: Carlos Pérez" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-id-card"></i> Cédula
                    </label>
                    <input class="form-input" type="text"
                           asp-for="Cedula" placeholder="Ej: 1234567890" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-location-dot"></i> Dirección
                    </label>
                    <input class="form-input" type="text"
                           asp-for="Direccion" placeholder="Ej: Calle 10 #20-30" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-venus-mars"></i> Género
                    </label>
                    <select class="form-select" asp-for="Genero">
                        <option value="">Seleccionar...</option>
                        <option value="Masculino">Masculino</option>
                        <option value="Femenino">Femenino</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Datos laborales -->
        <div class="form-section">
            <p class="form-section-title">
                <i class="fa-solid fa-briefcase"></i>
                Datos laborales
            </p>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-briefcase"></i> Cargo
                    </label>
                    <input class="form-input" type="text"
                           asp-for="Cargo" placeholder="Ej: Vendedor" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-calendar"></i> Fecha de ingreso
                    </label>
                    <input class="form-input" type="date" asp-for="FechaIngreso" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-dollar-sign"></i> Valor día
                    </label>
                    <input class="form-input" type="number"
                           asp-for="ValorDia" placeholder="Ej: 50000" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-calendar-days"></i> Días trabajados
                    </label>
                    <input class="form-input" type="number"
                           asp-for="DiasTrabajados" placeholder="Ej: 30" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-building-columns"></i> Número banco
                    </label>
                    <input class="form-input" type="text"
                           asp-for="NumeroBanco" placeholder="Ej: 1234567890" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-shield"></i> Número ARL
                    </label>
                    <input class="form-input" type="text"
                           asp-for="NumeroARL" placeholder="Ej: ARL-12345" />
                </div>
            </div>
        </div>

        <!-- Acceso al sistema -->
        <div class="form-section">
            <p class="form-section-title">
                <i class="fa-solid fa-lock"></i>
                Acceso al sistema
            </p>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-user"></i> Nombre de usuario
                    </label>
                    <input class="form-input" type="text"
                           asp-for="Username" placeholder="Ej: carlos.vendedor" />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-lock"></i> Contraseña
                    </label>
                    <input class="form-input" type="password"
                           asp-for="Password" placeholder="Mínimo 6 caracteres" />
                </div>
                <div class="form-group full">
                    <label class="form-label">
                        <i class="fa-solid fa-key"></i> Rol del sistema
                    </label>
                    <select class="form-select" asp-for="RolId">
                        <option value="">Seleccionar rol...</option>
                        @if (Model.Roles != null)
                        {
                            @foreach (var rol in Model.Roles)
                            {
                                <option value="@rol.Id">@rol.Nombre</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        <button type="submit" class="btn-submit">
            <i class="fa-solid fa-user-plus"></i>
            Crear empleado
        </button>

    </form>
</div>
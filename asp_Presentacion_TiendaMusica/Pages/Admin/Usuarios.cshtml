@page
@model asp_Presentacion_TiendaMusica.Pages.Admin.UsuariosModel

@{
    ViewData["Title"] = "Usuarios";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 32px;
        font-weight: 800;
        color: #f5c542;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .btn-back {
        background: transparent;
        color: #9ca3af;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 8px 14px;
        font-size: 13px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-back:hover {
            color: #f5c542;
            border-color: #f5c542;
        }

    .alert-success {
        background: rgba(100,180,60,0.12);
        border: 1px solid rgba(100,180,60,0.25);
        color: #7ec850;
        font-size: 13px;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .table-wrapper {
        background: linear-gradient(145deg, #111111, #1a1a1a);
        border: 1px solid #2a2a2a;
        border-radius: 20px;
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead tr {
        background: rgba(245,197,66,0.1);
        border-bottom: 1px solid #2a2a2a;
    }

    thead th {
        padding: 14px 18px;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        color: #f5c542;
        letter-spacing: 0.05em;
    }

    tbody tr {
        border-bottom: 1px solid #1e1e1e;
        transition: 0.2s ease;
    }

        tbody tr:hover {
            background: rgba(245,197,66,0.04);
        }

    tbody td {
        padding: 14px 18px;
        font-size: 13px;
        color: #d0c0a0;
    }

    .badge-activo {
        background: rgba(100,180,60,0.15);
        color: #7ec850;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 8px;
        font-weight: 600;
    }

    .badge-inactivo {
        background: rgba(220,60,60,0.15);
        color: #e07070;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 8px;
        font-weight: 600;
    }

    .badge-rol {
        background: rgba(245,197,66,0.12);
        color: #f5c542;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 8px;
        font-weight: 600;
    }

    .actions {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-toggle-on {
        background: rgba(220,60,60,0.12);
        color: #e07070;
        border: 1px solid rgba(220,60,60,0.2);
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
        transition: 0.2s ease;
    }

        .btn-toggle-on:hover {
            background: rgba(220,60,60,0.25);
            border-color: #e07070;
        }

    .btn-toggle-off {
        background: rgba(100,180,60,0.12);
        color: #7ec850;
        border: 1px solid rgba(100,180,60,0.2);
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
        transition: 0.2s ease;
    }

        .btn-toggle-off:hover {
            background: rgba(100,180,60,0.25);
            border-color: #7ec850;
        }

    .rol-form {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .rol-select {
        padding: 6px 10px;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
        font-size: 12px;
        background: #0d0d0d;
        color: #f0e8d0;
        cursor: pointer;
    }

        .rol-select:focus {
            outline: none;
            border-color: #f5c542;
        }

    .btn-rol {
        background: rgba(245,197,66,0.12);
        color: #f5c542;
        border: 1px solid rgba(245,197,66,0.2);
        border-radius: 8px;
        padding: 6px 10px;
        font-size: 12px;
        cursor: pointer;
        transition: 0.2s ease;
    }

        .btn-rol:hover {
            background: rgba(245,197,66,0.25);
            border-color: #f5c542;
        }

    .empty-state {
        text-align: center;
        padding: 3rem;
        color: #9ca3af;
    }

        .empty-state i {
            font-size: 48px;
            color: #2a2a2a;
            margin-bottom: 1rem;
            display: block;
        }
</style>

<div class="page-header">
    <div style="display:flex; align-items:center; gap:16px;">
        <a href="/Admin/Dashboard" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i>
            Dashboard
        </a>
        <h1 class="page-title">
            <i class="fa-solid fa-user-cog"></i>
            Usuarios
        </h1>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.MensajeExito))
{
    <div class="alert-success">
        <i class="fa-solid fa-circle-check"></i>
        @Model.MensajeExito
    </div>
}

<div class="table-wrapper">
    @if (Model.Lista == null || !Model.Lista.Any())
    {
        <div class="empty-state">
            <i class="fa-solid fa-users"></i>
            <p>No hay usuarios registrados todavía.</p>
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Fecha Creación</th>
                    <th>Estado</th>
                    <th>Rol actual</th>
                    <th>Cambiar rol</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var usuario in Model.Lista)
                {
                    var rolNombre = Model.ObtenerRolNombre(usuario.Id);
                    var rolId = Model.ObtenerRolId(usuario.Id);
                    <tr>
                        <td style="color:#6a5a3a;">#@usuario.Id</td>
                        <td>@usuario.Username</td>
                        <td style="color:#9ca3af;">
                            @usuario.FechaCreacion.ToString("dd/MM/yyyy")
                        </td>
                        <td>
                            @if (usuario.Activo)
                            {
                                <span class="badge-activo">Activo</span>
                            }
                            else
                            {
                                <span class="badge-inactivo">Inactivo</span>
                            }
                        </td>
                        <td>
                            <span class="badge-rol">@rolNombre</span>
                        </td>

                        <!-- Cambiar rol -->
                        <td>
                            <form method="post" class="rol-form">
                                <input type="hidden" name="usuarioId"
                                       value="@usuario.Id" />
                                <input type="hidden" name="rolActualId"
                                       value="@rolId" />
                                <select name="nuevoRolId" class="rol-select">
                                    @if (Model.Roles != null)
                                    {
                                        @foreach (var rol in Model.Roles)
                                        {
                                            <option value="@rol.Id"
                                                    selected="@(rol.Id == rolId)">
                                                @rol.Nombre
                                            </option>
                                        }
                                    }
                                </select>
                                <button type="submit"
                                        asp-page-handler="CambiarRol"
                                        class="btn-rol"
                                        title="Guardar rol">
                                    <i class="fa-solid fa-check"></i>
                                </button>
                            </form>
                        </td>

                        <!-- Activar / Desactivar -->
                        <td>
                            <form method="post">
                                <input type="hidden" name="id"
                                       value="@usuario.Id" />
                                <input type="hidden" name="activo"
                                       value="@usuario.Activo.ToString().ToLower()" />
                                @if (usuario.Activo)
                                {
                                    <button type="submit"
                                            asp-page-handler="ToggleActivo"
                                            class="btn-toggle-on">
                                        <i class="fa-solid fa-ban"></i>
                                        Desactivar
                                    </button>
                                }
                                else
                                {
                                    <button type="submit"
                                            asp-page-handler="ToggleActivo"
                                            class="btn-toggle-off">
                                        <i class="fa-solid fa-circle-check"></i>
                                        Activar
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
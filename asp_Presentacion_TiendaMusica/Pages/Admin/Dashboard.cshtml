@page
@model asp_Presentacion_TiendaMusica.Pages.Admin.DashboardModel

@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<div class="dashboard-container">


    <div class="dashboard-header">
        <div>
            <h1>Dashboard</h1>
            <p>Panel administrativo principal</p>
        </div>
        <div class="admin-profile">
            <div class="admin-avatar">
                <i class="fa-solid fa-user-shield"></i>
            </div>
            <div>
                <h4>@Model.NombreAdmin</h4>
                <span>Sistema Aurum Sound</span>
            </div>
        </div>
    </div>

    <div class="cards-grid">
        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon">
                    <i class="fa-solid fa-box"></i>
                </div>
                <div>
                    <h2>@Model.TotalProductos</h2>
                    <p>Productos</p>
                </div>
            </div>
        </div>
        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon">
                    <i class="fa-solid fa-users"></i>
                </div>
                <div>
                    <h2>@Model.TotalClientes</h2>
                    <p>Clientes</p>
                </div>
            </div>
        </div>
        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon">
                    <i class="fa-solid fa-cart-shopping"></i>
                </div>
                <div>
                    <h2>@Model.TotalFacturas</h2>
                    <p>Ventas</p>
                </div>
            </div>
        </div>
        <div class="dashboard-card">
            <div class="card-content">
                <div class="card-icon">
                    <i class="fa-solid fa-briefcase"></i>
                </div>
                <div>
                    <h2>@Model.TotalEmpleados</h2>
                    <p>Empleados</p>
                </div>
            </div>
        </div>
    </div>


    <div class="dashboard-panel">
        <div class="panel-title">
            <h3>Accesos rápidos</h3>
        </div>
        <div class="quick-grid">
            <a href="/Admin/Productos" class="quick-card">
                <i class="fa-solid fa-box"></i>
                <span>Productos</span>
            </a>
            <a href="/Admin/Clientes" class="quick-card">
                <i class="fa-solid fa-users"></i>
                <span>Clientes</span>
            </a>
            <a href="/Admin/Empleados" class="quick-card">
                <i class="fa-solid fa-briefcase"></i>
                <span>Empleados</span>
            </a>
            <a href="/Admin/Facturas" class="quick-card">
                <i class="fa-solid fa-file-invoice"></i>
                <span>Facturas</span>
            </a>
            <a href="/Admin/ReparacionesGarantias" class="quick-card">
                <i class="fa-solid fa-warehouse"></i>
                <span>Reparaciones y Garantías</span>
            </a>
            <a href="/Admin/Proveedores" class="quick-card">
                <i class="fa-solid fa-truck"></i>
                <span>Proveedores</span>
            </a>
            <a href="/Admin/Auditorias" class="quick-card">
                <i class="fa-solid fa-clipboard-list"></i>
                <span>Auditorías</span>
            </a>
            <a href="/Admin/Usuarios" class="quick-card">
                <i class="fa-solid fa-user-cog"></i>
                <span>Usuarios</span>
            </a>
        </div>
    </div>

</div>

<style>
    body {
        background: #050505;
    }

    .dashboard-container {
        min-height: 100vh;
        padding: 35px;
        background: radial-gradient(circle at top left, rgba(255,183,0,0.10), transparent 25%), radial-gradient(circle at bottom right, rgba(255,183,0,0.08), transparent 25%), #050505;
        color: white;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

        .dashboard-header h1 {
            font-size: 42px;
            font-weight: 800;
            color: #f5c542;
            margin-bottom: 8px;
        }

        .dashboard-header p {
            color: #9ca3af;
            font-size: 15px;
        }

    .admin-profile {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 14px 20px;
        background: #111111;
        border: 1px solid #2a2a2a;
        border-radius: 18px;
    }

    .admin-avatar {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #f5c542, #b8860b);
        color: black;
        font-size: 22px;
    }


    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 22px;
        margin-bottom: 35px;
    }

    .dashboard-card {
        background: linear-gradient(145deg, #111111, #1a1a1a);
        border: 1px solid #2a2a2a;
        border-radius: 24px;
        padding: 28px;
        transition: 0.3s ease;
        box-shadow: 0 10px 25px rgba(0,0,0,0.5);
    }

        .dashboard-card:hover {
            transform: translateY(-8px);
            border-color: #f5c542;
        }

    .card-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-icon {
        width: 65px;
        height: 65px;
        border-radius: 18px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: rgba(245,197,66,0.12);
        color: #f5c542;
        font-size: 28px;
    }

    .dashboard-card h2 {
        font-size: 34px;
        font-weight: 800;
        margin-bottom: 5px;
    }

    .dashboard-card p {
        color: #9ca3af;
        font-size: 15px;
    }


    .dashboard-panel {
        background: linear-gradient(145deg, #111111, #171717);
        border: 1px solid #2a2a2a;
        border-radius: 24px;
        padding: 28px;
    }

    .panel-title {
        margin-bottom: 25px;
    }

        .panel-title h3 {
            font-size: 24px;
            color: #f5c542;
            font-weight: 700;
        }

   
    .quick-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
    }

    .quick-card {
        text-decoration: none;
        color: white;
        background: #1b1b1b;
        border: 1px solid #2d2d2d;
        border-radius: 20px;
        padding: 30px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
        transition: 0.3s ease;
    }

        .quick-card:hover {
            transform: translateY(-5px);
            border-color: #f5c542;
            background: #222222;
        }

        .quick-card i {
            font-size: 30px;
            color: #f5c542;
        }

        .quick-card span {
            font-weight: 600;
        }

    @@media(max-width: 1100px) {
        .quick-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(max-width: 768px) {
        .dashboard-container {
            padding: 20px;
        }

        .dashboard-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }

            .dashboard-header h1 {
                font-size: 34px;
            }

        .quick-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
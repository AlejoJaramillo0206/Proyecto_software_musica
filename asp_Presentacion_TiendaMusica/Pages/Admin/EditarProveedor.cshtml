@page
@model asp_Presentacion_TiendaMusica.Pages.Admin.EditarProveedorModel

@{
    ViewData["Title"] = "Editar Proveedor";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 2rem;
    }

    .btn-back {
        background: transparent;
        color: #9ca3af;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 8px 14px;
        font-size: 13px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-back:hover {
            color: #f5c542;
            border-color: #f5c542;
        }

    .page-title {
        font-size: 32px;
        font-weight: 800;
        color: #f5c542;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-wrapper {
        max-width: 600px;
    }

    .form-section {
        background: linear-gradient(145deg, #111111, #1a1a1a);
        border: 1px solid #2a2a2a;
        border-radius: 20px;
        padding: 28px;
        margin-bottom: 20px;
    }

    .form-section-title {
        font-size: 16px;
        font-weight: 600;
        color: #f5c542;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding-bottom: 12px;
        border-bottom: 1px solid #2a2a2a;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .form-label {
        font-size: 13px;
        color: #9ca3af;
    }

    .form-input {
        padding: 10px 14px;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        font-size: 14px;
        background: #0d0d0d;
        color: #f0e8d0;
    }

        .form-input:focus {
            outline: none;
            border-color: #f5c542;
        }

    .btn-submit {
        background: #f5c542;
        color: #1a1208;
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        justify-content: center;
    }

        .btn-submit:hover {
            background: #e0b030;
        }

    .error-msg {
        background: rgba(220,60,60,0.12);
        border: 1px solid rgba(220,60,60,0.25);
        color: #e07070;
        font-size: 13px;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="page-header">
    <a href="/Admin/Proveedores" class="btn-back">
        <i class="fa-solid fa-arrow-left"></i>
        Volver
    </a>
    <h1 class="page-title">
        <i class="fa-solid fa-pen"></i>
        Editar Proveedor
    </h1>
</div>

<div class="form-wrapper">
    @if (!string.IsNullOrEmpty(Model.ErrorMensaje))
    {
        <div class="error-msg">
            <i class="fa-solid fa-circle-exclamation"></i>
            @Model.ErrorMensaje
        </div>
    }

    <form method="post">
        <input type="hidden" asp-for="Id" />
        <div class="form-section">
            <p class="form-section-title">
                <i class="fa-solid fa-truck"></i>
                Datos del proveedor
            </p>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Código</label>
                    <input class="form-input" type="text" asp-for="Codigo" />
                </div>
                <div class="form-group">
                    <label class="form-label">Nombre empresa</label>
                    <input class="form-input" type="text" asp-for="Nombre_Empresa" />
                </div>
                <div class="form-group">
                    <label class="form-label">Teléfono</label>
                    <input class="form-input" type="text" asp-for="Telefono" />
                </div>
                <div class="form-group">
                    <label class="form-label">Correo</label>
                    <input class="form-input" type="email" asp-for="Correo" />
                </div>
            </div>
        </div>

        <button type="submit" class="btn-submit">
            <i class="fa-solid fa-floppy-disk"></i>
            Guardar cambios
        </button>
    </form>
</div>
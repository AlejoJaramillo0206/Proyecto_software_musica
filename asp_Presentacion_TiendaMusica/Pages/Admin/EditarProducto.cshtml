@page "{id:int}"
@model asp_Presentacion_TiendaMusica.Pages.Admin.Productos.EditarProductoModel

@{
    ViewData["Title"] = "Editar Producto";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 2rem;
    }

    .btn-back {
        background: transparent;
        color: #9ca3af;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 8px 14px;
        font-size: 13px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-back:hover {
            color: #f5c542;
            border-color: #f5c542;
        }

    .page-title {
        font-size: 32px;
        font-weight: 800;
        color: #f5c542;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-wrapper {
        max-width: 800px;
    }

    .form-section {
        background: linear-gradient(145deg, #111111, #1a1a1a);
        border: 1px solid #2a2a2a;
        border-radius: 20px;
        padding: 28px;
        margin-bottom: 20px;
    }

    .form-section-title {
        font-size: 16px;
        font-weight: 600;
        color: #f5c542;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding-bottom: 12px;
        border-bottom: 1px solid #2a2a2a;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .form-group.full {
            grid-column: span 2;
        }

    .form-label {
        font-size: 13px;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .form-input, .form-select {
        padding: 10px 14px;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        font-size: 14px;
        background: #0d0d0d;
        color: #f0e8d0;
        transition: 0.2s ease;
    }

        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #f5c542;
        }

    .btn-submit {
        background: #f5c542;
        color: #1a1208;
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        width: 100%;
        justify-content: center;
    }

        .btn-submit:hover {
            background: #e0b030;
        }

    .toggle-group {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        background: #0d0d0d;
    }

    .toggle-label {
        font-size: 14px;
        color: #d0c0a0;
    }

    .tipo-badge {
        background: rgba(245,197,66,0.12);
        color: #f5c542;
        border: 1px solid rgba(245,197,66,0.3);
        border-radius: 10px;
        padding: 6px 14px;
        font-size: 13px;
        font-weight: 600;
    }
</style>

<div class="page-header">
    <a href="/Admin/Productos" class="btn-back">
        <i class="fa-solid fa-arrow-left"></i>
        Volver
    </a>
    <h1 class="page-title">
        <i class="fa-solid fa-pen"></i>
        Editar Producto
    </h1>
    <span class="tipo-badge">@Model.TipoProducto</span>
</div>

<div class="form-wrapper">
    <form method="post" asp-route-tipoProducto="@Model.TipoProducto">
        <input type="hidden" asp-for="Id" />

        <!-- Datos comunes -->
        <div class="form-section">
            <p class="form-section-title">
                <i class="fa-solid fa-box"></i>
                Datos del producto
            </p>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Código</label>
                    <input class="form-input" type="text" asp-for="Codigo" />
                </div>
                <div class="form-group">
                    <label class="form-label">Nombre</label>
                    <input class="form-input" type="text" asp-for="Nombre" />
                </div>
                <div class="form-group">
                    <label class="form-label">Precio</label>
                    <input class="form-input" type="number"
                           step="0.01" asp-for="Precio" />
                </div>
                <div class="form-group">
                    <label class="form-label">Proveedor</label>
                    <select class="form-select" asp-for="ProveedorId">
                        @if (Model.Proveedores != null)
                        {
                            @foreach (var p in Model.Proveedores)
                            {
                                <option value="@p.Id"
                                        selected="@(p.Id == Model.ProveedorId)">
                                    @p.Nombre_Empresa
                                </option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        <!-- Campos especificos según tipo -->
        @if (Model.TipoProducto == "AlbumesClasicos")
        {
            <div class="form-section">
                <p class="form-section-title">
                    <i class="fa-solid fa-music"></i> Álbum Clásico
                </p>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Compositor</label>
                        <input class="form-input" type="text" asp-for="Compositor" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Intérprete</label>
                        <input class="form-input" type="text" asp-for="Interprete" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Orquesta</label>
                        <input class="form-input" type="text" asp-for="Orquesta" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Época musical</label>
                        <input class="form-input" type="text" asp-for="EpocaMusical" />
                    </div>
                    <div class="form-group full">
                        <div class="toggle-group">
                            <input type="checkbox" asp-for="GrabacionesEnVivo" />
                            <label class="toggle-label">¿Grabaciones en vivo?</label>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.TipoProducto == "AlbumesPop")
        {
            <div class="form-section">
                <p class="form-section-title">
                    <i class="fa-solid fa-music"></i> Álbum Pop
                </p>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Cantidad canciones</label>
                        <input class="form-input" type="number"
                               asp-for="CantidadCanciones" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Featuring</label>
                        <input class="form-input" type="text" asp-for="Featuring" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Nominaciones</label>
                        <input class="form-input" type="number"
                               asp-for="Nominaciones" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Sello discográfico</label>
                        <input class="form-input" type="text"
                               asp-for="SelloDiscografico" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Duración (min)</label>
                        <input class="form-input" type="number"
                               asp-for="DuracionMinutos" />
                    </div>
                </div>
            </div>
        }

        @if (Model.TipoProducto == "AlbumesReggaeton")
        {
            <div class="form-section">
                <p class="form-section-title">
                    <i class="fa-solid fa-music"></i> Álbum Reggaetón
                </p>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Idioma</label>
                        <input class="form-input" type="text" asp-for="Idioma" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Productor</label>
                        <input class="form-input" type="text" asp-for="Productor" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Colaboraciones</label>
                        <input class="form-input" type="text"
                               asp-for="ColabDestacadas" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Estilo</label>
                        <input class="form-input" type="text"
                               asp-for="EstiloReggaeton" />
                    </div>
                    <div class="form-group full">
                        <div class="toggle-group">
                            <input type="checkbox" asp-for="Explicito" />
                            <label class="toggle-label">¿Contenido explícito?</label>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.TipoProducto == "AlbumesRock")
        {
            <div class="form-section">
                <p class="form-section-title">
                    <i class="fa-solid fa-music"></i> Álbum Rock
                </p>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Autor</label>
                        <input class="form-input" type="text" asp-for="Autor" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Año lanzamiento</label>
                        <input class="form-input" type="number"
                               asp-for="AñoLanzamiento" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Sello discográfico</label>
                        <input class="form-input" type="text"
                               asp-for="SelloDiscograficoRock" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Subgénero</label>
                        <input class="form-input" type="text" asp-for="SubgeneroRock" />
                    </div>
                    <div class="form-group full">
                        <div class="toggle-group">
                            <input type="checkbox" asp-for="EdicionRemaster" />
                            <label class="toggle-label">¿Edición remasterizada?</label>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.TipoProducto == "InstrumentosCuerdas")
        {
            <div class="form-section">
                <p class="form-section-title">
                    <i class="fa-solid fa-guitar"></i> Instrumento Cuerdas
                </p>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Marca</label>
                        <input class="form-input" type="text" asp-for="Marca" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Color</label>
                        <input class="form-input" type="text" asp-for="Color" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Material</label>
                        <input class="form-input" type="text" asp-for="Material" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Cantidad cuerdas</label>
                        <input class="form-input" type="number"
                               asp-for="CantidadCuerdas" />
                    </div>
                    <div class="form-group full">
                        <div class="toggle-group">
                            <input type="checkbox" asp-for="IncluyeEstuche" />
                            <label class="toggle-label">¿Incluye estuche?</label>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.TipoProducto == "InstrumentosAire")
        {
            <div class="form-section">
                <p class="form-section-title">
                    <i class="fa-solid fa-wind"></i> Instrumento Aire
                </p>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Tipo</label>
                        <input class="form-input" type="text" asp-for="TipoAire" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Año fabricación</label>
                        <input class="form-input" type="number"
                               asp-for="AñoFabricacion" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Peso (kg)</label>
                        <input class="form-input" type="number"
                               step="0.01" asp-for="Peso" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Afinación</label>
                        <input class="form-input" type="text" asp-for="Afinacion" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Material boquilla</label>
                        <input class="form-input" type="text"
                               asp-for="MaterialBoquilla" />
                    </div>
                </div>
            </div>
        }

        @if (Model.TipoProducto == "InstrumentosPercusion")
        {
            <div class="form-section">
                <p class="form-section-title">
                    <i class="fa-solid fa-drum"></i> Instrumento Percusión
                </p>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Tipo</label>
                        <input class="form-input" type="text" asp-for="TipoPercusion" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tamaño</label>
                        <input class="form-input" type="text" asp-for="Tamaño" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Peso (kg)</label>
                        <input class="form-input" type="number"
                               step="0.01" asp-for="PesoPercusion" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Material parche</label>
                        <input class="form-input" type="text"
                               asp-for="MaterialParche" />
                    </div>
                    <div class="form-group full">
                        <div class="toggle-group">
                            <input type="checkbox" asp-for="IncluyeBaquetas" />
                            <label class="toggle-label">¿Incluye baquetas?</label>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.TipoProducto == "Bafles")
        {
            <div class="form-section">
                <p class="form-section-title">
                    <i class="fa-solid fa-volume-high"></i> Bafle
                </p>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Tamaño</label>
                        <input class="form-input" type="text" asp-for="TamañoBafle" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Decibeles</label>
                        <input class="form-input" type="number" asp-for="Decibeles" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Marca</label>
                        <input class="form-input" type="text" asp-for="MarcaBafle" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Potencia (watts)</label>
                        <input class="form-input" type="number"
                               asp-for="PotenciaWatts" />
                    </div>
                    <div class="form-group full">
                        <div class="toggle-group">
                            <input type="checkbox" asp-for="Bluetooth" />
                            <label class="toggle-label">¿Tiene Bluetooth?</label>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.TipoProducto == "Accesorios")
        {
            <div class="form-section">
                <p class="form-section-title">
                    <i class="fa-solid fa-toolbox"></i> Accesorio
                </p>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Tipo</label>
                        <input class="form-input" type="text" asp-for="TipoAccesorio" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Color</label>
                        <input class="form-input" type="text"
                               asp-for="ColorAccesorio" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Tamaño</label>
                        <input class="form-input" type="text"
                               asp-for="TamañoAccesorio" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Compatibilidad</label>
                        <input class="form-input" type="text"
                               asp-for="Compatibilidad" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Hecho en</label>
                        <input class="form-input" type="text" asp-for="HechoEn" />
                    </div>
                </div>
            </div>
        }

        <button type="submit" class="btn-submit">
            <i class="fa-solid fa-floppy-disk"></i>
            Guardar cambios
        </button>
    </form>
</div>